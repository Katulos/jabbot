{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Run app",
            "type": "python",
            "request": "launch",
            "python": "${command:python.interpreterPath}",
            "console": "integratedTerminal",
            "module": "app",
            "args": ["start"],
            "cwd": "${workspaceRoot}"
        },
        {
            "name": "Python: Debug app",
            "type": "debugpy",
            "request": "launch",
            "stopOnEntry": false,
            "justMyCode": true,
            "python": "${command:python.interpreterPath}",
            "console": "internalConsole",
            "internalConsoleOptions": "openOnSessionStart",
            "module": "app",
            "args": ["start"],
            "cwd": "${workspaceRoot}"
        },
        {
            "name": "Python: Run Current File",
            "type": "python",
            "request": "launch",
            "stopOnEntry": false,
            "python": "${command:python.interpreterPath}",
            "program": "${file}",
            "console": "internalConsole"
        }
    ]
}
